rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "sabbirrahmansr904@gmail.com")
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    // Products: Anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Banners: Anyone can read, only admin can write
    match /banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Settings: Anyone can read, only admin can write
    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Coupons: Anyone can read, only admin can write
    match /coupons/{couponId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Reviews: Anyone can read and create, only admin can delete/update
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true; // Allow anonymous reviews for now since original app didn't require auth
      allow update, delete: if isAdmin();
    }

    // Orders: Anyone can create (checkout), only admin can read/update/delete
    match /orders/{orderId} {
      allow create: if true; // Allow anonymous checkout
      allow read, update, delete: if isAdmin();
    }

    // Customers: Only admin can read/write
    match /customers/{customerId} {
      allow read, write: if isAdmin();
    }

    // Users (Roles): Users can read their own, admin can read/write all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
